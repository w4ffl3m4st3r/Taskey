{% extends "layouts/error.html.twig" %}

{% block title %}500{% endblock %}

{% block content %}
    <div class="text-center px-8">

        <h1 class="text-9xl font-extrabold text-red-500">500</h1>

        <div class="w-24 h-1 bg-red-500 mx-auto my-6 rounded"></div>

        <h2 class="text-2xl font-semibold">
            Internal error
        </h2>

        <p class="text-gray-400 mt-4 max-w-md mx-auto">
            An internal error has occurred. Apologies for the inconvenience.
        </p>

        <a href="/"
           class="mt-10 inline-block bg-red-600 hover:bg-red-900
