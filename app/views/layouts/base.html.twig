<!DOCTYPE html>
<html lang="eng">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        if (localStorage.getItem('theme') === 'dark') {
            document.documentElement.classList.add('dark');
        }
        tailwind.config = {
            darkMode: 'class'
        }
    </script>

    <title>Taskey - {% block title %}{% endblock %}</title>
</head>

<body class="bg-white text-slate-800 dark:bg-[#0b0f19] dark:text-slate-100 min-h-screen flex flex-col antialiased">

<!-- Navbar -->
<nav class="bg-white dark:bg-[#0d1117] border-b border-slate-200 dark:border-slate-800">
    <div class="max-w-6x1 mx-auto px-6 py-4 flex justify-between items-center">

        <!-- menu -->
        <div class="space-x-6 text-slate-700 dark:text-slate-300">
            <a href="/" class="hover:text-slate-900 dark:hover:text-white transition">Home</a>
            <a href="/about" class="hover:text-slate-900 dark:hover:text-white transition">About</a>
            <a href="/tasks" class="hover:text-slate-900 dark:hover:text-white transition">Tasks</a>
            <a href="/tasks/create" class="hover:text-slate-900 dark:hover:text-white transition">Create</a>
        </div>

        <!-- light/darkmode toggle button -->
        <button id="themeToggle"
                class="relative inline-flex h-6 w-11 items-center rounded-full bg-slate-400 dark:bg-slate-700 transition">
            <span class="inline-block h-4 w-4 transform rounded-full bg-white transition translate-x-1 dark:translate-x-6"></span>
        </button>

    </div>
</nav>

<!-- Content -->
<main class="flex-grow max-w-7x1 mx-auto p-8">
    {% block content %}{% endblock %}
</main>

<!-- Footer -->
<footer class="bg-white dark:bg-[#161b22] border-t border-slate-200 dark:border-[#30363d]">
    <div class="max-w-6xl mx-auto px-6 py-4 text-center text-sm text-slate-500 dark:text-[#8b949e]">
        © {{ "now"|date("Y") }} Taskey
    </div>
</footer>

<script>
    const toggleBtn = document.getElementById('themeToggle');

    // Load the light/dark theme
    if (localStorage.getItem('theme') === 'dark') {
        document.documentElement.classList.add('dark');
    }

    toggleBtn.addEventListener('click', () => {
        document.documentElement.classList.toggle('dark');

        if (document.documentElement.classList.contains('dark')) {
            localStorage.setItem('theme', 'dark');
        } else {
            localStorage.setItem('theme', 'light');
        }
    });
</script>
</body>
</html>