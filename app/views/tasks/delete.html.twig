{% extends "layouts/taskBase.html.twig" %}

{% block title %}Are you sure you want to delete?{% endblock %}

{% block content %}
    <form method="POST" action="/tasks/{{ task.id }}/delete">
        <div class="bg-white dark:bg-gray-800 shadow-md rounded-lg overflow-hidden">

            <div class="bg-gray-100 dark:bg-gray-700 px-6 py-4 border-b border-gray-200 dark:border-gray-600">
                <strong class="text-gray-800 dark:text-gray-100 text-lg">Delete Task</strong>
            </div>

            <div class="px-6 py-6 space-y-3">
                <p class="text-gray-700 dark:text-gray-300">
                    Are you sure you want to delete the task
                    <strong class="text-gray-900 dark:text-white">{{ task.title }}</strong>?
                </p>

                <p class="text-sm text-red-600 dark:text-red-400">
                    This action cannot be undone.
                </p>
            </div>

            <div class="px-6 py-4 border-t border-gray-200 dark:border-gray-600 flex space-x-2">
                <button type="submit"
                        class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded">
                    Delete Task
                </button>

                <a href="/tasks"
                   class="bg-gray-500 hover:bg-gray-600 text-white px-4 py-2 rounded">
                    Cancel
                </a>
            </div>

        </div>
    </form>
{% endblock %}